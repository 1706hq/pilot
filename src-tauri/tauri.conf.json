{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pilot",
  "version": "0.1.0",
  "identifier": "ai.1706.pilot",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "lumin",
        "width": 1280,
        "height": 860,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#050506",
        "minWidth": 480,
        "minHeight": 360
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
