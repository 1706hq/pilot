{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pilot",
  "version": "0.4.0",
  "identifier": "ai.1706.pilot",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "PILOT",
        "width": 1280,
        "height": 860,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "backgroundColor": "#050506",
        "minWidth": 480,
        "minHeight": 360
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "background": "dmg-background.png",
        "windowSize": { "width": 700, "height": 440 },
        "appPosition": { "x": 170, "y": 150 },
        "applicationFolderPosition": { "x": 530, "y": 150 }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1NDBBRjZCMEYyQUY4RTkKUldUcCtDb1BhNjlBeFFRM2JJdVN0WHcvVkJRS1BEK2pQMityY2hNVlBjbW9FR2xtT3l2b0VtekEK",
      "endpoints": [
        "https://github.com/1706hq/pilot/releases/latest/download/latest.json"
      ]
    }
  }
}
